# Copy this file to .env on the Ubuntu VM and adjust values for your network.
# Do not commit the real .env file.

# Optional: bind AdGuard DNS to a specific VM LAN IP to avoid conflicts with
# Ubuntu's loopback resolver. Example: 192.168.1.50
ADGUARD_DNS_BIND_IP=LAN_VM_IP

# Hosts allowed to access Homepage. Include LAN and private remote access hosts.
# Example: 192.168.1.50:3002,100.x.y.z:3002
HOMEPAGE_ALLOWED_HOSTS=LAN_VM_IP:3002,TAILSCALE_VM_IP:3002
